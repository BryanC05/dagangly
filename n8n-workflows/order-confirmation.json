{
    "name": "MSME - Order Confirmation Email",
    "nodes": [
        {
            "parameters": {
                "httpMethod": "POST",
                "path": "order-created",
                "responseMode": "onReceived",
                "options": {}
            },
            "id": "trigger-1",
            "name": "Order Webhook",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 1.1,
            "position": [
                250,
                300
            ]
        },
        {
            "parameters": {
                "fromEmail": "={{ $env.SMTP_USER || 'your.email@gmail.com' }}",
                "toEmail": "={{ $json.data.buyer.email }}",
                "subject": "Order Confirmation #{{ $json.data.orderNumber }} - MSME Marketplace",
                "text": "Hi {{ $json.data.buyer.name }},\n\nYour order #{{ $json.data.orderNumber }} has been placed successfully!\n\nOrder Details:\n- Total: Rp {{ $json.data.totalAmount.toLocaleString() }}\n- Status: {{ $json.data.status }}\n- Seller: {{ $json.data.seller.name }}\n\nThank you for shopping at MSME Marketplace!\n\n---\nMSME Marketplace Team",
                "options": {}
            },
            "id": "smtp-1",
            "name": "Send Confirmation Email",
            "type": "n8n-nodes-base.emailSend",
            "typeVersion": 2,
            "position": [
                500,
                300
            ],
            "credentials": {
                "smtp": {
                    "id": "REPLACE_WITH_SMTP_CREDENTIAL_ID",
                    "name": "Gmail SMTP"
                }
            }
        }
    ],
    "connections": {
        "Order Webhook": {
            "main": [
                [
                    {
                        "node": "Send Confirmation Email",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        }
    },
    "settings": {
        "executionOrder": "v1"
    },
    "meta": {
        "instanceId": "msme-marketplace"
    }
}